import UIKit
import AVFoundation

class SoundPlayer: NSObject {
    //シンバルの音源データを読み込み
    let cymbalData = NSDataAsset(name: "cymbalSound")!.data.base64EncodedData
    //シンバル用プレイヤーの変数
    var cymbalPlayer: AYAudioPlayer!
    
    func cymbalPlay() {
        do {
            //シンバル用のプレイヤーに、音源データを指定
            cymbalPlayer = try AVAudioPlayer(data: cymbalData)
            
            //シンバルの音源再生
            cymbalPlayer.play()
        }catch {
            print("シンバルで、エラーが発生しました")
        }
    }// cymbalPlayここまで
    
}
